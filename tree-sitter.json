{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tsv",
      "camelcase": "Tsv",
      "title": "Tsv",
      "scope": "source.tsv",
      "file-types": [
        "tsv"
      ],
      "injection-regex": "^tsv$",
      "class-name": "TreeSitterTsv"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tsv grammar for tree-sitter",
    "authors": [
      {
        "name": "shotarokuramata",
        "email": "shokuramata@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-tsv",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}